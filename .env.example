# API base URL para el backend de Lookiar.
# Si está definida, se usa RemoteGeoRepository (HTTP).
# Si está ausente, se usa LocalGeoRepository (IndexedDB).
#
# En Vercel: Settings → Environment Variables → VITE_API_URL
#
# Ejemplo con Rails local:
# VITE_API_URL=http://localhost:3000
#
# Ejemplo producción:
# VITE_API_URL=https://api.lookiar.com
VITE_API_URL=

# API key de OpenRouteService para guía de rutas peatonales.
# Obtener en: https://openrouteservice.org/dev/#/signup (plan gratuito disponible)
# En Vercel: Settings → Environment Variables → VITE_OPENROUTESERVICE_API_KEY
#
# IMPORTANTE: En producción mover esta llamada al backend Rails para no exponer la key.
VITE_OPENROUTESERVICE_API_KEY=

# API key de MapTiler para tiles premium (calidad visual, zoom máximo 20).
# Obtener en: https://cloud.maptiler.com/account/keys (plan gratuito disponible)
# En Vercel: Settings → Environment Variables → VITE_MAPTILER_KEY
VITE_MAPTILER_KEY=
