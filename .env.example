# API base URL para el backend de Lookiar.
# Si está definida, se usa RemoteGeoRepository (HTTP).
# Si está ausente, se usa LocalGeoRepository (IndexedDB).
#
# En Vercel: Settings → Environment Variables → VITE_API_URL
#
# Ejemplo con Rails local:
# VITE_API_URL=http://localhost:3000
#
# Ejemplo producción:
# VITE_API_URL=https://api.lookiar.com
VITE_API_URL=
